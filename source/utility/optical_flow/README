#include <stdio.h>
#include "log_sys.h"
#include "imu_driver.h"
#include "task_manager.h"
#include "lora_state.h"
#include "file_system.h"
#include "gb_timer.h"
#include "buzzer.h"
#include "ms5611.h"
#include "spi_bus.h"
#include "io_define.h"
#include "gpio_setting.h"
#include "pmw3901.h"

#include "freertos/FreeRTOS.h"
#include "freertos/task.h"

void app_main(void)
{
    GB_LogSystemInit();
    GB_MutexInitialize();

    GB_SleepMs(5000);     // Waiting USB Log Ready
    fspi.begin(&fspi, MPU_FSPI_MOSI, MPU_FSPI_MISO, MPU_FSPI_SCLK, SPI_MAX_DMA_LEN);
    fspi.addDevice(&fspi, GB_SPI_DEV_0, 0, 0, SPI_DEVICE_NO_DUMMY, PMW3901_SPI_SPEED, -1);

    GB_GPIO_Reset( MPU_FSPI_CS );
    GB_GPIO_SetDirection( MPU_FSPI_CS, GB_GPIO_OUTPUT );
    GB_GPIO_Set(MPU_FSPI_CS, 1);

    GB_GPIO_Reset( BARO_SPI_CS );
    GB_GPIO_SetDirection( BARO_SPI_CS, GB_GPIO_OUTPUT );
    GB_GPIO_Set(BARO_SPI_CS, 1);

    GB_PMW3901_DEV_T opt_dev;
    CHK_EXIT(GB_PMW3901_InitDesc(&opt_dev, &fspi, GB_SPI_DEV_0, PMW3901_SPI_CS));
    CHK_EXIT(GB_PMW3901_Init(&opt_dev));

    int16_t deltaX, deltaY;
    while (1)
    {
        CHK_EXIT(GB_PMW3901_GetMotion(&opt_dev, &deltaX, &deltaY));
        GB_DEBUGI(OPF_TAG, "Optical Flow - dx: %d, dy: %d", deltaX, deltaY);

        GB_SleepMs(1000);
    }
    return;
}
